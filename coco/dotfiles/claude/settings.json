{
  "permissions": {
    "allow": [
      "Bash(tricorder status)",
      "Bash(tricorder status --wait)"
    ]
  },
  "enabledPlugins": {
    "tricorder@atelier": true
  },
  "extraKnownMarketplaces": {
    "cgeorgii-plugins": {
      "source": {
        "source": "directory",
        "path": "/home/cgeorgii/.claude/plugins/cgeorgii"
      }
    },
    "atelier": {
      "source": {
        "source": "directory",
        "path": "/home/cgeorgii/code/tricorder"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "showThinkingSummaries": false,
  "model": "sonnet"
}
